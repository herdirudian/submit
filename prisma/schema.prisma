// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model for Authentication (NextAuth) and Form ownership
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // Hashed password
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  forms         Form[]
  notifications Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // Link to the relevant page (e.g., response details)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// Form model
model Form {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  logo        String?    // URL/Path to the logo image
  logoWidth   Int        @default(128) // Width in pixels
  titleFontSize Int      @default(30)  // Font size in pixels
  descriptionFontSize Int @default(16) // Font size in pixels
  
  // Theme Customization
  primaryColor        String?    @default("#0f4d39") // Main button/highlight color
  backgroundColor     String?    @default("#f8fafc") // Page background color
  fontFamily          String?    @default("var(--font-deskripsi)")   // Font family

  // Sidebar / Contact Info Fields
  sidebarTitle        String?    @default("The Lodge")
  sidebarSubtitle     String?    @default("Maribaya")
  sidebarDescription  String?    @db.Text
  contactAddress      String?    @db.Text
  contactPhone        String?
  contactEmail        String?
  contactWorkingHours String?
  socialInstagram     String?
  socialTiktok        String? // Added Tiktok
  socialWebsite       String?
  showSidebar         Boolean    @default(true) // Option to show/hide sidebar

  // Email & Thank You Page Customization
  emailSubject        String?    @default("Submission Received") // Subject for respondent email
  emailBody           String?    @db.Text // Custom message body for respondent email
  thankYouTitle       String?    @default("Thank You!")
  thankYouMessage     String?    @db.Text
  redirectUrl         String?    // Optional redirect after submit

  slug        String     @unique // Public URL identifier e.g. /forms/my-survey
  status      FormStatus @default(DRAFT)
  views       Int        @default(0) // Track number of visits
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   Question[]
  responses   Response[]

  @@index([userId])
  @@map("forms")
}

model AppSettings {
  id                    String   @id
  brandName             String?
  brandLogoUrl          String?
  notificationFromName  String?
  notificationFromEmail String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("app_settings")
}

enum FormStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

// Question model
model Question {
  id          String       @id @default(cuid())
  formId      String
  type        QuestionType
  label       String
  description String?
  placeholder String?
  required    Boolean      @default(false)
  validation  String?      @db.Text // JSON: { regex, min, max, minLength, maxLength }
  logic       String?      @db.Text // JSON: { condition: "equals", value: "abc", targetQuestionId: "xyz" }
  order       Int          // For sorting questions
  
  form        Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  options     QuestionOption[]
  answers     Answer[]

  @@index([formId])
  @@map("questions")
}

enum QuestionType {
  SHORT_TEXT
  PARAGRAPH
  NUMBER
  EMAIL
  PHONE
  DROPDOWN
  RADIO
  CHECKBOX
  DATE
  FILE_UPLOAD
  SECTION_BREAK
}

// Options for questions like Dropdown, Radio, Checkbox
model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  label      String
  value      String
  order      Int

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

// Response model (Form Submission)
model Response {
  id          String   @id @default(cuid())
  formId      String
  submittedAt DateTime @default(now())
  
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@index([formId])
  @@map("responses")
}

// Answer model (Individual answers in a response)
model Answer {
  id          String   @id @default(cuid())
  responseId  String
  questionId  String
  
  // Storing value as text. For complex types (like checkbox array), serialize to JSON string.
  value       String?  @db.Text 
  
  response    Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
  @@map("answers")
}
